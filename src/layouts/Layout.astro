---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ECONMADE — анимационный канал про экономику и финансы. Топы, рейтинги, объяснения простым языком." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#000000" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Анимационный канал про экономику и финансы" />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Silkscreen:wght@400;700&family=Inter:wght@400;500&display=swap');

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: #000;
    color: #ccc;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3, .pixel {
    font-family: 'Silkscreen', monospace;
  }

  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 20px;
  }

  a {
    color: #fff;
    text-decoration: none;
  }

  a:hover {
    color: #aaa;
  }

  /* Hero */
  .hero {
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 24px;
  }

  .hero h1 {
    font-size: clamp(3rem, 12vw, 6rem);
    color: #fff;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .tagline {
    font-size: 0.95rem;
    color: #666;
    max-width: 400px;
    line-height: 1.6;
  }

  /* Links row */
  .socials {
    display: flex;
    gap: 24px;
    margin-top: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .socials a {
    font-family: 'Silkscreen', monospace;
    font-size: 0.75rem;
    color: #555;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.15s;
  }

  .socials a:hover {
    color: #fff;
  }

  /* Divider */
  .divider {
    border: none;
    border-top: 1px solid #1a1a1a;
    margin: 64px 0;
  }

  /* Section */
  .section {
    margin-bottom: 64px;
  }

  .section h2 {
    font-size: 1rem;
    color: #fff;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  /* Articles list */
  .articles {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .article {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 16px 0;
    border-bottom: 1px solid #111;
    gap: 16px;
  }

  .article-title {
    font-size: 0.95rem;
    color: #ddd;
    transition: color 0.15s;
  }

  .article:hover .article-title {
    color: #fff;
  }

  .article-date {
    font-family: 'Silkscreen', monospace;
    font-size: 0.65rem;
    color: #444;
    white-space: nowrap;
  }

  /* About */
  .about-text {
    font-size: 0.9rem;
    color: #888;
    line-height: 1.8;
  }

  /* Footer */
  footer {
    padding: 48px 0;
    text-align: center;
    border-top: 1px solid #111;
  }

  footer p {
    font-family: 'Silkscreen', monospace;
    font-size: 0.6rem;
    color: #333;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Scroll indicator */
  .scroll-hint {
    font-family: 'Silkscreen', monospace;
    font-size: 0.6rem;
    color: #333;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 40px;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.8; }
  }
</style>
