---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — ECONMADE`}>
  <Nav />
  <main>
    <article class="post">
      <header>
        <a href="/blog/" class="back">&larr; Блог</a>
        <h1>{post.data.title}</h1>
        <div class="meta">
          <span class="date">{post.data.date}</span>
          {post.data.tags && (
            <div class="tags">
              {post.data.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>
      <div class="content">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  .post {
    padding: 80px 0;
  }

  .back {
    font-family: 'Silkscreen', monospace;
    font-size: 0.7rem;
    color: #444;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: inline-block;
    margin-bottom: 32px;
    transition: color 0.15s;
  }

  .back:hover {
    color: #fff;
  }

  .post h1 {
    font-size: 1.8rem;
    color: #fff;
    letter-spacing: 0.02em;
    line-height: 1.3;
    margin-bottom: 16px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 48px;
  }

  .date {
    font-family: 'Silkscreen', monospace;
    font-size: 0.6rem;
    color: #444;
  }

  .tags {
    display: flex;
    gap: 8px;
  }

  .tag {
    font-family: 'Silkscreen', monospace;
    font-size: 0.55rem;
    color: #555;
    border: 1px solid #222;
    padding: 2px 8px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .content {
    font-size: 0.95rem;
    color: #aaa;
    line-height: 1.9;
  }

  .content :global(h2) {
    font-family: 'Silkscreen', monospace;
    font-size: 1rem;
    color: #fff;
    margin-top: 40px;
    margin-bottom: 16px;
    letter-spacing: 0.05em;
  }

  .content :global(p) {
    margin-bottom: 16px;
  }

  .content :global(strong) {
    color: #ddd;
  }

  .content :global(ul), .content :global(ol) {
    margin-bottom: 16px;
    padding-left: 20px;
  }

  .content :global(li) {
    margin-bottom: 6px;
  }

  .content :global(hr) {
    border: none;
    border-top: 1px solid #1a1a1a;
    margin: 40px 0;
  }

  .content :global(em) {
    color: #666;
  }
</style>
