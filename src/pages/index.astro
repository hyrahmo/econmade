---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ECONMADE — Экономика просто">
  <main>
    <section class="hero">
      <div class="logo-mark">
        <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="icon">
          <rect width="48" height="48" rx="12" fill="#0D0D0D"/>
          <path d="M12 34V14h6v8h12v-8h6v20h-6v-8H18v8z" fill="#00E676"/>
        </svg>
      </div>
      <h1>ECON<span class="accent">MADE</span></h1>
      <p class="tagline">Экономика и финансы — просто, ярко, анимационно</p>
      <div class="links">
        <a href="https://youtube.com/@econmade" class="btn" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          YouTube
        </a>
        <a href="https://t.me/econmade" class="btn btn-outline" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0h-.056zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          Telegram
        </a>
      </div>
    </section>

    <section class="about">
      <h2>Что такое ECONMADE?</h2>
      <div class="cards">
        <div class="card">
          <div class="card-icon">📊</div>
          <h3>Топы и рейтинги</h3>
          <p>Самые богатые страны, крупнейшие компании, экономические рекорды — в ярких анимациях</p>
        </div>
        <div class="card">
          <div class="card-icon">💡</div>
          <h3>Просто о сложном</h3>
          <p>Инфляция, ВВП, криптовалюты — объясняем так, что поймёт каждый</p>
        </div>
        <div class="card">
          <div class="card-icon">🎬</div>
          <h3>Анимация</h3>
          <p>Динамичные визуализации и motion-графика — экономика никогда не была такой наглядной</p>
        </div>
      </div>
    </section>

    <footer>
      <p>&copy; 2026 ECONMADE. Экономика, сделанная понятной.</p>
    </footer>
  </main>
</Layout>
