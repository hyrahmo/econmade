---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Layout title="ECONMADE">
  <Nav />
  <main>
    <section class="hero">
      <h1>ECONMADE</h1>
      <p class="tagline">Экономика и финансы в анимации. Топы, рейтинги, разборы — просто о сложном.</p>

      <nav class="socials">
        <a href="https://youtube.com/@econmade" target="_blank" rel="noopener">YouTube</a>
        <a href="https://t.me/econmade" target="_blank" rel="noopener">Telegram</a>
        <a href="https://tiktok.com/@econmade" target="_blank" rel="noopener">TikTok</a>
        <a href="https://instagram.com/econmade" target="_blank" rel="noopener">Instagram</a>
        <a href="https://x.com/econmade" target="_blank" rel="noopener">X</a>
      </nav>

      <div class="scroll-hint">scroll</div>
    </section>

    <hr class="divider" />

    <section class="section">
      <h2>Latest</h2>
      <div class="articles">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="article">
            <span class="article-title">{post.data.title}</span>
            <span class="article-date">{post.data.date}</span>
          </a>
        ))}
      </div>
      <a href="/blog/" class="view-all">Все статьи &rarr;</a>
    </section>

    <hr class="divider" />

    <section class="section">
      <h2>About</h2>
      <p class="about-text">
        ECONMADE — анимационный канал про экономику и финансы.
        Мы делаем сложные экономические темы понятными через визуализации,
        топы и motion-графику. Подписывайся и смотри мир экономики по-новому.
      </p>
    </section>

    <footer>
      <p>&copy; 2026 ECONMADE</p>
    </footer>
  </main>
</Layout>

<style>
  .view-all {
    display: inline-block;
    margin-top: 24px;
    font-family: 'Silkscreen', monospace;
    font-size: 0.7rem;
    color: #444;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.15s;
  }

  .view-all:hover {
    color: #fff;
  }
</style>
